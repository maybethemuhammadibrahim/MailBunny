# MailMind — Environment Variables
# Copy this file to .env and fill in all values before running the app.

OPENAI_API_KEY=        # From platform.openai.com → API Keys
GOOGLE_CLIENT_ID=      # From Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=  # From Google Cloud Console → Credentials → OAuth 2.0 Client Secret
REDIRECT_URI=http://localhost:8000/auth/callback
SECRET_KEY=            # Any random string for session signing (e.g. run: python -c "import secrets; print(secrets.token_hex(32))")
DATABASE_PATH=./mailmind.db
